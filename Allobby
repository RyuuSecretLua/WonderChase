local IsAtStart = false
local CountdownFinished = false
local ForceStop = false

local function GetHRP()
local c = Player.Character
return c and c:FindFirstChild("HumanoidRootPart")
end

local function ResetState()
RemainingTime, IsAtStart, CountdownFinished, TouchedStickers = 0, false, false, {}
end

local function touch(part)
local hrp = GetHRP()
if hrp then
firetouchinterest(hrp, part, 0)
firetouchinterest(hrp, part, 1)
end
end

local function TeleportTo(targetPos)
local hrp = GetHRP()
if not hrp then return end
hrp.CFrame = CFrame.new(targetPos)
end

local function SetGravity(val)
Workspace.Gravity = val
end

local function GetNearestStart()
local hrp = GetHRP() if not hrp then return end
local folder = Workspace:FindFirstChild("Utility") and Workspace.Utility:FindFirstChild("ObbyColliders")
if not folder then return end
local nearest, minDist = nil, math.huge
for _, v in folder:GetChildren() do
if v.Name == "GameStart" and v:IsA("BasePart") then
local d = (hrp.Position - v.Position).Magnitude
if d < minDist then minDist, nearest = d, v end
end
end
return nearest
end

local function CollectPickupsOnce()
local pickups = Workspace:FindFirstChild("Pickups")
if not pickups then return end
local hrp = GetHRP()
if not hrp then return end
local count = 0
local items = pickups:GetChildren()
for _, item in ipairs(items) do
if not AutoPlayEnabled or ForceStop then return end
if count >= 5 then break end
local part = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart", true)
if part then
SetGravity(10)
hrp.CFrame = part.CFrame
touch(part)
SetGravity(20)
count += 1
task.wait(1.5)
end
end
end

local function GetStickerNumber(part)
local current = part
local lastNum = nil
while current do
local num = tonumber(current.Name:match("%d+"))
if num then lastNum = num end
current = current.Parent
end
return lastNum or 0
end

local function CollectStickers(token)
while AutoPlayEnabled and not CountdownFinished and not ForceStop and LoopToken == token do
local targets = {}
for _, folderName in ipairs({"Stickers", "ActiveStickers"}) do
local f = Workspace:FindFirstChild(folderName)
if f then
for _, v in f:GetDescendants() do
if v:IsA("BasePart") and (v.Name == "Default" or v.Name == "Touch") then
if not TouchedStickers[v] then
table.insert(targets, v)
end
end
end
end
end
if #targets > 0 then
local hrp = GetHRP()
if hrp then
table.sort(targets, function(a, b)
return GetStickerNumber(a) < GetStickerNumber(b)
end)
local t = targets[1]
TouchedStickers[t] = true
TeleportTo(t.Position)
touch(t)
WindUI:Notify({
Title = "Teleported",
Content = "To: " .. t:GetFullName(),
Duration = 2,
})
task.wait(0.5)
CollectPickupsOnce()
task.wait(1)
end
else
task.wait(1.5)
end
task.wait()
end
end

local function FirePortal()
local portalCollision = Workspace:FindFirstChild("Utility")
and Workspace.Utility:FindFirstChild("Teleporters")
and Workspace.Utility.Teleporters:FindFirstChild("Portal_to_Wc")
and Workspace.Utility.Teleporters.Portal_to_Wc:FindFirstChild("Collision")
if portalCollision then
TeleportTo(portalCollision.Position)
touch(portalCollision)
end
end

local function MainLoop(token)
while AutoPlayEnabled and not ForceStop and LoopToken == token do
if not IsAtStart then
local startPart = GetNearestStart()
if startPart then
TeleportTo(startPart.Position)
touch(startPart)
end
if AutoPlayEnabled and not ForceStop then
IsAtStart = true
RemainingTime = PortalDelay
CountdownFinished = false
TouchedStickers = {}
end
end
CollectStickers(token)
if CountdownFinished and AutoPlayEnabled and not ForceStop and LoopToken == token then
for _ = 1, 4 do
FirePortal()
task.wait(PortalFireDelay)
end
task.wait(1.5)
pcall(function()
local gui = Player.PlayerGui.PlayerUi.Popups.ObbyResults
if gui and gui.Visible then
local btn = gui:FindFirstChild("ReplayButton", true)
if btn and btn.Visible then
local pos = btn.AbsolutePosition + btn.AbsoluteSize / 2
VirtualInputManager:SendMouseButtonEvent(pos.X, pos.Y + 50, 0, true, game, 0)
task.wait(1.5)
VirtualInputManager:SendMouseButtonEvent(pos.X, pos.Y + 50, 0, false, game, 0)
end
end
end)
task.wait(1.5)
ResetState()
end
task.wait(1.5)
end
end

